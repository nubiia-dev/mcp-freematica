{
  "name": "@nubiia/mcp-freematica",
  "version": "0.6.1",
  "description": "MCP server for Freemática REST API (consumed by Claude via Nubiia)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcp-freematica": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write src tests",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepack": "npm run build",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubiia-dev/mcp-freematica.git"
  },
  "bugs": {
    "url": "https://github.com/nubiia-dev/mcp-freematica/issues"
  },
  "homepage": "https://github.com/nubiia-dev/mcp-freematica#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "freematica",
    "nubiia"
  ],
  "author": "Nubiia",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.7.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.1",
    "pino": "^10.3.1",
    "uuid": "^14.0.0",
    "zod": "^3.23.8"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "@vitest/ui": "^3.2.6",
    "dotenv": "^16.0.0",
    "eslint": "^9.0.0",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nock": "^13.5.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.0",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0",
    "vitest": "^3.2.6"
  }
}
