# Required: Freemática API credentials (provided by Nubiia at runtime)
FREEMATICA_AUTH_TOKEN=
FREEMATICA_AUTH_COMPANY=
FREEMATICA_AUTH_ORGANIZATION=
FREEMATICA_AUTH_APP=
FREEMATICA_AUTH_SESSION=

# Optional: HTTP transport
FREEMATICA_BASE_URL=https://api-p01.clientservicepanel.com/restsat/api
MCP_PORT=3000
MCP_ALLOWED_ORIGINS=*

# Optional: HTTP client hardening (v0.5.0)
# Timeout por petición en ms (default: 30000 = 30s)
FREEMATICA_TIMEOUT_MS=30000
# Número máximo de reintentos para errores 5xx/red (default: 3)
FREEMATICA_MAX_RETRIES=3
# Umbral de fallos consecutivos para abrir el circuit breaker (default: 5)
FREEMATICA_CIRCUIT_BREAKER_THRESHOLD=5
# Tiempo en ms que el circuit breaker permanece abierto (default: 30000 = 30s)
FREEMATICA_CIRCUIT_BREAKER_TIMEOUT_MS=30000

# Optional: Logging
# Nivel de log: trace | debug | info | warn | error | fatal (default: info)
LOG_LEVEL=info
